# Copy this file to .env.development / .env.staging / .env.production
# and fill in the values. Never commit real secrets in a real project.

NODE_ENV=development
PORT=3000

MONGODB_URI=mongodb://127.0.0.1:27017/nest_app_dev
# mongodb://localhost:27017/

JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=1d

UPLOAD_DIR=uploads

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin@123
SEED_USER_EMAIL=user@example.com
SEED_USER_PASSWORD=User@123

# Mail (SMTP). Leave MAIL_HOST empty in dev to auto-use an Ethereal test inbox
# (an online catch-all that gives a preview URL). If offline, it falls back to a
# JSON transport so the app still boots.
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=Nest App <no-reply@nest-app.local>
